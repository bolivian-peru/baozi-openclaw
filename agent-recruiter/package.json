{
  "name": "@baozi/agent-recruiter",
  "version": "2.0.0",
  "type": "module",
  "description": "AI Agent Recruiter — discovers, onboards, and tracks AI agents to trade on Baozi prediction markets. Uses @baozi.bet/mcp-server direct handler imports.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "baozi-recruiter": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "npx tsx src/cli.ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --config jest.config.js",
    "test:live": "npx tsx src/tests/test-live-integration.ts",
    "lint": "eslint src/ --ext .ts",
    "discover": "npx tsx src/cli.ts discover",
    "onboard": "npx tsx src/cli.ts onboard",
    "dashboard": "npx tsx src/cli.ts dashboard",
    "pitch": "npx tsx src/cli.ts pitch"
  },
  "dependencies": {
    "@baozi.bet/mcp-server": "^5.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "tsx": "^4.7.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
