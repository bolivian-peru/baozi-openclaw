{
  "name": "@baozi/claim-alert-agent",
  "version": "1.0.0",
  "description": "Portfolio notification agent for Baozi prediction markets — monitors wallets and alerts on claimable winnings, odds shifts, and closing markets",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claim-alert": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js monitor",
    "dev": "tsx src/cli.ts monitor",
    "test": "tsx src/tests/run.ts",
    "check": "node dist/cli.js check",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "date-fns": "^4.1.0",
    "nodemailer": "^6.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
