# x402 Marketplace Configuration

# Database path (defaults to ./marketplace.db)
DB_PATH=./marketplace.db

# Marketplace operator wallet (receives platform fees)
OPERATOR_WALLET=YOUR_OPERATOR_WALLET_ADDRESS

# Platform fee rate (0-1, e.g. 0.05 = 5%)
PLATFORM_FEE_RATE=0.05

# Affiliate commission rate (0-1, e.g. 0.10 = 10%)
AFFILIATE_COMMISSION_RATE=0.10

# x402 Payment simulation mode (true = simulate, false = real)
# Set to false when x402 protocol is fully deployed
X402_SIMULATE=true

# Solana RPC endpoint (used for market data)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Default analysis price in SOL (if analyst doesn't specify)
DEFAULT_ANALYSIS_PRICE_SOL=0.001
