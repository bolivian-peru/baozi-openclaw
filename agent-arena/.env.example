# Solana RPC endpoint (optional — defaults to public mainnet)
# Using a dedicated RPC (Helius, QuickNode) is recommended for production
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Server port (optional, defaults to 3000)
PORT=3000

# Agent wallets to track (comma-separated Solana addresses)
# These are the AI agent wallets you want to monitor in the arena
# Example: AGENT_WALLETS=Wallet1,Wallet2,Wallet3
AGENT_WALLETS=
