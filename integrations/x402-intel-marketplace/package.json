{
  "name": "@baozi/x402-intel-marketplace",
  "version": "1.0.0",
  "description": "Agent-to-agent prediction market intel marketplace with x402 micropayments and on-chain reputation tracking",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "x402-market": "dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli/main.js",
    "dev": "tsx src/cli/main.ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --passWithNoTests",
    "register": "tsx src/cli/main.ts register",
    "publish": "tsx src/cli/main.ts publish",
    "browse": "tsx src/cli/main.ts browse",
    "buy": "tsx src/cli/main.ts buy",
    "reputation": "tsx src/cli/main.ts reputation",
    "demo": "tsx src/cli/main.ts demo"
  },
  "dependencies": {
    "@baozi.bet/mcp-server": "^5.0.0",
    "dotenv": "^16.4.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
