# Baozi x402 Intel Marketplace — Environment Variables

# Solana RPC endpoint (use Helius, QuickNode, etc. — NOT public RPC)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Analyst/buyer wallet address (base58 public key)
WALLET_ADDRESS=YourBase58WalletAddressHere

# Analyst private key (base58, 64-byte keypair) — needed for publishing analyses and signing x402 payments
# WARNING: Never commit real keys. Use a dedicated keypair for this agent.
SOLANA_PRIVATE_KEY=YourBase58PrivateKeyHere

# Baozi API base URL (optional override)
BAOZI_API_URL=https://baozi.bet

# x402 payment facilitator URL (optional — leave empty to use simulated payments)
# When set, real x402 payment proofs will be submitted here
X402_FACILITATOR_URL=

# Marketplace storage path (default: ./data)
MARKETPLACE_DATA_DIR=./data

# Server port (for running as HTTP API)
PORT=3000

# Log level: debug | info | warn | error
LOG_LEVEL=info
