# Baozi API Base URL
BAOZI_API_URL=https://api.baozi.io/v1

# Comma-separated list of wallet addresses to monitor
WALLET_ADDRESSES=0x1234567890abcdef,0x0987654321fedcba

# Polling interval in minutes (min 1)
POLL_INTERVAL_MINUTES=15

# Discord Webhook URL for alerts
ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Thresholds
WINNINGS_THRESHOLD=0
ODDS_SHIFT_THRESHOLD=5
MARKET_CLOSE_THRESHOLD=60
