# Baozi MCP Server (optional - for production)
MCP_SERVER_URL=http://localhost:3000

# Your affiliate code from https://baozi.bet/affiliate
AFFILIATE_CODE=

# Your Solana wallet address
WALLET_ADDRESS=

# Platform to post: agentbook, twitter, telegram
POST_PLATFORM=agentbook

# Polling interval in milliseconds (default: 60s)
POLL_INTERVAL=60000

# Event thresholds
LARGE_BET_THRESHOLD=5
ODDS_SWING_THRESHOLD=0.10
