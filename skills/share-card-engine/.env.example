# Baozi API
BAOZI_API_URL=https://baozi.bet/api

# Wallet (for affiliate code and signing)
WALLET_ADDRESS=your_solana_wallet_address

# OpenAI for caption generation (optional, falls back to templates)
OPENAI_API_KEY=sk-...

# Affiliate code (register via MCP build_register_affiliate_transaction)
AFFILIATE_CODE=your_affiliate_code

# Platform posting (at least one required)
# AgentBook (uses wallet address, no extra auth needed)
AGENTBOOK_ENABLED=true

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Poll interval in seconds (default 60)
POLL_INTERVAL_SEC=60
