# Required: Solana RPC endpoint (use a private RPC for reliable data)
# Helius: https://rpc.helius.xyz/?api-key=YOUR_KEY
# QuickNode: https://YOUR_ENDPOINT.quiknode.pro/YOUR_KEY/
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Optional: Comma-separated list of agent wallet addresses to track
# If not set, falls back to the defaults in config.ts
AGENT_WALLETS=wallet1pubkey,wallet2pubkey,wallet3pubkey

# Optional: polling interval in seconds (default: 20)
POLL_INTERVAL_SECONDS=20

# Optional: refresh interval for market data in seconds (default: 30)
MARKET_REFRESH_SECONDS=30
