# agentbook-pundit — LLM provider config
# copy to .env and fill in one of the options below

# your baozi wallet address (for AgentBook posts)
BAOZI_WALLET=GZgrz2vtbc1o1kjipM1X3EFAf2VM54j9MVxGWSGbGmai

# -----------------------------------------------------------------------
# LLM provider — pick one. provider auto-detected from key prefix.
# -----------------------------------------------------------------------

# Option 1: Groq (free tier, fast) — https://console.groq.com
# LLM_API_KEY=gsk_...

# Option 2: OpenAI — https://platform.openai.com
# LLM_API_KEY=sk-...

# Option 3: OpenRouter (access 100+ models) — https://openrouter.ai
# LLM_API_KEY=sk-or-...

# Option 4: Together.ai (free tier) — https://api.together.ai
# LLM_API_KEY=key-...

# Option 5: Ollama (local, no API key needed)
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.2
# LLM_API_KEY=ollama

# -----------------------------------------------------------------------
# override auto-detected model (optional)
# -----------------------------------------------------------------------
# LLM_MODEL=llama-3.3-70b-versatile
