#!/usr/bin/env node
/**
 * analyze-market — statistical summary of a market.
 *
 * Usage:
 *   scripts/analyze-market <market-id>
 *   scripts/analyze-market --market-id <pubkey>
 */

import { callMcp } from '../lib/mcp.mjs';
import { parseArgs, printJson, die, usage } from '../lib/cli.mjs';

const args = parseArgs();
const marketId = args.marketId || args._[0];
if (!marketId) usage([
  'usage: scripts/analyze-market <market-id>',
]);

try {
  const market = await callMcp('get_market', { market: marketId });
  if (!market || market.error) die(market?.error || 'market not found');

  const totalPool = Number(market.totalPoolSol ?? 0);
  const yesPool = Number(market.yesPoolSol ?? 0);
  const noPool = Number(market.noPoolSol ?? 0);
  const yesPct = market.yesPercent ?? 50;
  const noPct = market.noPercent ?? 50;

  const favorite = yesPool === noPool ? 'even'
    : yesPool > noPool ? 'Yes' : 'No';

  // Pari-mutuel implied return for 1 SOL bet on each side
  // payout = bet * totalPool / (sidePool + bet)  (before fees)
  const betExample = 1;
  const yesPayout = totalPool > 0 ? (betExample * (totalPool + betExample)) / (yesPool + betExample) : 0;
  const noPayout = totalPool > 0 ? (betExample * (totalPool + betExample)) / (noPool + betExample) : 0;

  const closing = market.closingTime ? new Date(market.closingTime) : null;
  const hoursRemaining = closing
    ? Math.max(0, Math.round((closing.getTime() - Date.now()) / 3_600_000))
    : null;

  printJson({
    publicKey: market.publicKey || marketId,
    marketId: market.marketId,
    question: market.question,
    layer: market.layer,
    status: market.status,
    isBettingOpen: market.isBettingOpen,
    closingTime: market.closingTime,
    hoursRemaining,
    summary: {
      favorite,
      yesPercent: yesPct,
      noPercent: noPct,
      liquidityTier:
        totalPool < 0.1 ? 'thin' :
        totalPool < 1 ? 'low' :
        totalPool < 10 ? 'medium' : 'deep',
    },
    pool: {
      yesSol: yesPool,
      noSol: noPool,
      totalSol: totalPool,
      skew: totalPool > 0 ? +((yesPool - noPool) / totalPool).toFixed(3) : 0,
    },
    impliedReturnOn1Sol: {
      yesPayoutSol: +yesPayout.toFixed(4),
      noPayoutSol: +noPayout.toFixed(4),
      note: 'gross payout before platform fee (~2.5-3%)',
    },
    fees: {
      platformBps: market.platformFeeBps,
      creatorBps: market.creatorFeeBps,
    },
  });
} catch (e) {
  die(e.message);
}
