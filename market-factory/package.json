{
  "name": "@baozi/market-factory",
  "version": "1.0.0",
  "description": "Auto-create Baozi prediction markets from news, sports, crypto, and event sources",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "scan": "npx tsx scripts/scan-news.ts",
