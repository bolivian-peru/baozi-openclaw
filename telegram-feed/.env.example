# Required: Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Solana RPC (default: public mainnet)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Baozi program ID (default: production)
BAOZI_PROGRAM_ID=BAoZirE2cAXqyjRap2GiGdAFkSB2nQJrPMBb6KMFj2gn

# Baozi website URL
BAOZI_BASE_URL=https://baozi.bet

# Default daily roundup schedule (cron, 9 AM UTC)
DEFAULT_ROUNDUP_CRON=0 9 * * *

# Default timezone
DEFAULT_TIMEZONE=UTC

# Max markets per list response
MAX_MARKETS_PER_PAGE=5

# Bot admin Telegram user IDs (comma-separated)
ADMIN_USER_IDS=

# Data storage directory
DATA_DIR=./data
