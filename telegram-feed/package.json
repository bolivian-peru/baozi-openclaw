{
  "name": "baozi-telegram-feed",
  "version": "1.0.0",
  "description": "Read-only Telegram bot for Baozi prediction market discovery and alerts",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "test:unit": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage --testPathIgnorePatterns=integration",
    "test:integration": "NODE_OPTIONS='--experimental-vm-modules' jest --testPathPattern=integration",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "lint": "eslint src/ --ext .ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "telegram",
    "prediction-markets",
    "solana",
    "baozi",
    "bot"
  ],
  "author": "manas-io-ai",
  "license": "MIT",
  "dependencies": {
    "@baozi.bet/mcp-server": "^4.0.11",
    "@solana/web3.js": "^1.95.0",
    "grammy": "^1.30.0",
    "node-cron": "^3.0.3",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0"
  }
}
