#!/usr/bin/env node

/**
 * create-markets — Run a full market creation cycle
 *
 * Usage: scripts/create-markets [--dry-run] [--max N] [--sources google-trends,coingecko]
 *
 * Scans trends, validates proposals, and creates Lab markets on Baozi.
 * Use --dry-run to validate without creating.
 */

import { runCycle, loadConfig } from "../dist/src/index.js";

// Parse CLI args
const args = process.argv.slice(2);

if (args.includes("--dry-run")) {
  process.env.DRY_RUN = "true";
}

const maxIdx = args.indexOf("--max");
if (maxIdx !== -1 && args[maxIdx + 1]) {
  process.env.MAX_MARKETS_PER_CYCLE = args[maxIdx + 1];
}

const sourceIdx = args.indexOf("--sources");
if (sourceIdx !== -1 && args[sourceIdx + 1]) {
  process.env.TREND_SOURCES = args[sourceIdx + 1];
}

if (args.includes("--json")) {
  process.env.OUTPUT_JSON = "true";
}

const config = loadConfig();
runCycle(config).catch(err => {
  console.error("Error:", err);
  process.exitCode = 1;
});
