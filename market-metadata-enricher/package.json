{
  "name": "@baozi/market-metadata-enricher",
  "version": "1.0.0",
  "description": "Agent that monitors newly created Lab markets and enriches them with quality metadata: descriptions, category tags, timing analysis, and quality scores",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "tsx src/__tests__/index.test.ts",
    "test:integration": "INTEGRATION=true tsx src/__tests__/integration.test.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@baozi.bet/mcp-server": "^4.0.11",
    "@solana/web3.js": "^1.98.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0"
  }
}
